{
  "name": "Creeper Panel Professional",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:22",
  "features": {
    "ghcr.io/devcontainers/features/java:1": {
      "version": "21",
      "jdkDistro": "temurin"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss"
      ]
    }
  },
  "forwardPorts": [3000, 25565, 19132],
  "portsAttributes": {
    "3000": {
      "label": "Painel Creeper",
      "onAutoForward": "openPreview"
    },
    "25565": {
      "label": "Minecraft Java"
    },
    "19132": {
      "label": "Minecraft Bedrock"
    }
  },
  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y tmux screen unzip && corepack enable && pnpm install && chmod +x scripts/*.sh",
  "postStartCommand": "./scripts/start-panel.sh",
  "remoteUser": "node"
}
